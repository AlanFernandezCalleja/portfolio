---
// Propiedades
export interface Props {
  title?: string;
  description?: string;
  imageSrc?: string;
  imageAlt?: string;
  technologies?: Array<"html" | "css" | "js" | "react">;
}

const {
  title = "Nombre del Proyecto",
  description = "Este proyecto se ha realizado con diferentes herramientas potentes",
  imageSrc = "https://picsum.photos/id/104/400/240", // imagen placeholder hermosa
  imageAlt = "Vista previa del proyecto",
  technologies = ["html", "css", "js"],
} = Astro.props;
---

<article class="card-proyecto">
  <div class="imagen-proyecto">
    <img src={imageSrc} alt={imageAlt} loading="lazy" />
  </div>

  <div class="info-proyecto">
    <h3 class="title">{title}</h3>
    <p class="description">{description}</p>
  </div>

  <div class="tecnologias">
    {
      technologies.includes("html") && (
        <span class="icono-html" aria-label="HTML5">
          <svg height="30px" width="30px" version="1.1" id="_x32_" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 512 512" xml:space="preserve" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <style type="text/css"> .st0{fill:#e95814;} </style> <g> <path class="st0" d="M256.005,0C114.611,0,0,114.611,0,255.996C0,397.39,114.611,512,256.005,512 C397.39,512,512,397.39,512,255.996C512,114.611,397.39,0,256.005,0z M187.066,203.112c0,0.366-0.157,0.689-0.436,0.916 l-72.053,53.582l72.053,53.608c0.279,0.192,0.436,0.541,0.436,0.89v33.07c0,0.41-0.201,0.776-0.532,0.968 c-0.148,0.079-0.296,0.13-0.471,0.13c-0.192,0-0.392-0.07-0.558-0.2L81.734,268.894c-0.27-0.201-0.445-0.541-0.445-0.898v-20.765 c0-0.366,0.174-0.706,0.445-0.907l103.771-77.18c0.166-0.131,0.366-0.192,0.558-0.192c0.174,0,0.323,0.044,0.471,0.13 c0.332,0.183,0.532,0.55,0.532,0.968V203.112z M238.519,360.404c-0.148,0.445-0.514,0.741-0.951,0.741h-29.006 c-0.331,0-0.628-0.175-0.82-0.472c-0.183-0.278-0.236-0.645-0.131-0.976l65.87-208.118c0.131-0.437,0.514-0.724,0.942-0.724h29.014 c0.314,0,0.628,0.166,0.811,0.454c0.183,0.288,0.236,0.654,0.131,0.994L238.519,360.404z M430.694,267.996 c0,0.357-0.156,0.698-0.436,0.898l-103.771,77.181c-0.166,0.13-0.357,0.2-0.558,0.2c-0.166,0-0.322-0.052-0.471-0.13 c-0.331-0.192-0.532-0.558-0.532-0.968v-33.062c0-0.357,0.157-0.706,0.436-0.898l72.053-53.608l-72.053-53.582 c-0.278-0.209-0.436-0.54-0.436-0.906V170.05c0-0.418,0.201-0.785,0.532-0.968c0.148-0.086,0.305-0.13,0.471-0.13 c0.201,0,0.392,0.061,0.558,0.192l103.771,77.18c0.28,0.201,0.436,0.541,0.436,0.907V267.996z"></path> </g> </g></svg>
        </span>
      )
    }
    {

      technologies.includes("css") && (
        <span class="icono-css" aria-label="CSS3">
          <svg height="30px" width="30px" fill="#187ce7" viewBox="-1.5 0 24 24" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="m19.366 21.423 1.913-21.423h-21.279l.025.278 1.885 21.148.016.176 8.633 2.398h.136l8.653-2.4.016-.176zm-8.708-16.744h6.183l-.186 2.16-6.1 2.712.102.488h5.724l-.659 7.551-5.086 1.41-5.084-1.408-.32-3.616h2.093l.168 1.833.016.178 3.085.82h.133l3.051-.848.015-.177.288-3.386.023-.276h-9.047l-.19-2.173 6.309-2.701-.1-.49h-6.48l-.185-2.08h6.24z"></path></g></svg>
        </span>
      )
    }
    {
      technologies.includes("js") && (
        <span class="icono-js" aria-label="JavaScript">
          <svg width="32" height="32" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="45" fill="#F7DF1E" />
            <text
              x="50"
              y="67"
              font-size="44"
              text-anchor="middle"
              fill="#000000"
              font-family="Arial, sans-serif"
              font-weight="bold"
            >
              JS
            </text>
          </svg>
        </span>
      )
    }
    {
      technologies.includes("react") && (
        <span class="icono-react" aria-label="React">
          <svg width="32" height="32" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="45" fill="#61DAFB" />
            <text
              x="50"
              y="67"
              font-size="40"
              text-anchor="middle"
              fill="#000000"
              font-family="Arial, sans-serif"
              font-weight="bold"
            >
              R
            </text>
          </svg>
        </span>
      )
    }
  </div>
</article>

<style>
  /* Reset y estilos base del card */
  .card-proyecto {
    max-width: 380px;
    background: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.3s ease;
    font-family: system-ui, "Segoe UI", "Inter", sans-serif;
    display: flex;
    flex-direction: column;
    backdrop-filter: blur(0px);
    border: 1px solid rgba(0, 0, 0, 0.05);
    
  }

  .card-proyecto:hover {
    transform: translate(-4px, -4px);
    border: 1px solid #0a0a0e;
    
    
  }

  /* Imagen */
  .imagen-proyecto {
    width: 100%;
    height: 180px;
    overflow: hidden;
    background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  }

  .imagen-proyecto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
  }



  /* Información del proyecto */
  .info-proyecto {
    padding: 1.25rem 1rem 0.75rem 1rem;
  }

  .title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1e1e2f;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.3px;
    line-height: 1.3;
  }

  .description {
    font-size: 0.9rem;
    color: #4a4a5a;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Contenedor de íconos/tecnologías */
  .tecnologias {
    padding: 0.75rem 1rem 1.25rem 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    border-top: 1px solid #f0f0f0;
    margin-top: 0.25rem;
  }

  /* Estilos base para cada ícono */
  .icono-html,
  .icono-css,
  .icono-js,
  .icono-react {
    display: inline-flex;
    transition: transform 1s linear;
    cursor: pointer;
  }

  .icono-html:hover,
  .icono-css:hover,
  .icono-js:hover,
  .icono-react:hover {
    transform: scale(1.05);
  }

  /* Ajuste responsivo para textos dentro de SVG */
  svg text {
    user-select: none;
  }

  /* Opcional: si se quiere un efecto de vidrio más sutil en cards oscuros, pero mantenemos claridad */
  @media (prefers-color-scheme: dark) {
    .card-proyecto {
      background: #1e1e2a;
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
    }

    .title {
      color: #f0f0f0;
    }

    .description {
      color: #b0b0c0;
    }

    .tecnologias {
      border-top-color: rgba(255, 255, 255, 0.1);
    }
  }

  /* Adaptación móvil */
  @media (max-width: 640px) {
    .card-proyecto {
      max-width: 100%;
    }
    .imagen-proyecto {
      height: 160px;
    }
  }
</style>
